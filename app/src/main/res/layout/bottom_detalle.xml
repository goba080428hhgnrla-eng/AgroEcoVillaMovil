<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="#ffffff">

    <TextView
        android:text="Características del producto"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:textColor="@color/txt_inicio"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Descripción completa -->
            <TextView
                android:text="Descripción"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtDescripcionCompleta"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="12dp" />

            <!-- Unidad de venta -->
            <TextView
                android:text="Unidad de venta"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtUnidadVentaDetalle"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="12dp" />

            <!-- Disponibilidad -->
            <TextView
                android:text="Disponibilidad"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtDisponibilidad"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="12dp" />

            <!-- Métodos de producción -->
            <TextView
                android:text="Métodos de producción"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtMetodosProduccion"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="12dp" />

            <!-- Logística -->
            <TextView
                android:text="Logística"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtLogistica"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="12dp" />

            <!-- Entregable -->
            <TextView
                android:text="Envío"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtEnvio"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="12dp" />

            <!-- Fecha de creación -->
            <TextView
                android:text="Publicado"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtFecha"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>