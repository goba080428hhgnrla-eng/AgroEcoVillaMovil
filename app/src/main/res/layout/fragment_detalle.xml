<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ENCABEZADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Nombre -->
            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tortillas"
                android:textSize="44sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="serif"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <!-- Imagen Principal -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/imgProducto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#DDDDDD"/>

                <!-- Indicador de posición -->
                <TextView
                    android:id="@+id/txtImageIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:background="#88000000"
                    android:padding="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_margin="8dp"
                    android:visibility="gone"/>

            </FrameLayout>

            <!-- ICONOS LATERALES -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginStart="8dp">

                <ImageButton
                    android:id="@+id/btnCarritoIcon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@android:drawable/ic_menu_add"
                    android:background="@android:color/transparent"/>

                <Button
                    android:id="@+id/btnFavorito"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="❤"
                    android:textColor="@color/agregar_fav"
                    android:textSize="22sp"
                    android:background="@android:color/transparent"/>

                <ImageButton
                    android:id="@+id/iconCompartir"
                    android:layout_width="45dp"
                    android:layout_height="45dp"

                    android:src="@android:drawable/ic_menu_share"
                    android:background="@android:color/transparent"

                     />

            </LinearLayout>

        </LinearLayout>

        <!-- CARRUSEL DE IMÁGENES MINIATURAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Galería"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp"/>

            <HorizontalScrollView
                android:id="@+id/scrollViewThumbnails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="horizontal">

                <LinearLayout
                    android:id="@+id/thumbnailContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp"/>

            </HorizontalScrollView>
        </LinearLayout>

        <!-- PRECIO -->
        <TextView
            android:id="@+id/txtPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$25"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="16dp"/>

        <!-- UNIDAD -->
        <TextView
            android:id="@+id/txtUnidadVenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kg"
            android:textColor="#666666"
            android:textSize="14sp"/>

        <!-- ENTREGABLE -->
        <TextView
            android:id="@+id/txtEntregable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Envío disponible"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"/>

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="18dp"/>

        <!-- BOTONES -->
        <Button
            android:id="@+id/btVerMas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver descripción completa"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/botones"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btDetalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver más detalles"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/botones"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btnAgregarCarrito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar al carrito"
            android:layout_marginTop="10dp"
            android:backgroundTint="#000000"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>