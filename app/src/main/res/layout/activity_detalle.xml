<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">


        <!-- ENCABEZADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Buscador -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="30dp"
                app:cardElevation="3dp">

                <EditText
                    android:id="@+id/buscador"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buscar producto..."
                    android:padding="14dp"
                    android:background="@android:color/white"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawableEnd="@android:drawable/ic_btn_speak_now"
                    android:drawablePadding="10dp"
                    android:textColor="#000000"
                    android:textColorHint="#777777"
                    android:imeOptions="actionSearch"
                    android:inputType="text"/>
            </androidx.cardview.widget.CardView>

            <!-- Nombre -->
            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tortillas"
                android:textSize="44sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="serif"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <!-- Imagen -->
            <ImageView
                android:id="@+id/imgProducto"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="#DDDDDD"/>

            <!-- ICONOS LATERALES -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginStart="8dp">

                <ImageButton
                    android:id="@+id/btnCarritoIcon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@android:drawable/ic_menu_add"
                    android:background="@android:color/transparent"/>

                <Button
                    android:id="@+id/btnFavorito"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="❤"
                    android:textColor="#FF0000"
                    android:textSize="22sp"
                    android:background="@android:color/transparent"/>

                <ImageButton
                    android:id="@+id/iconCompartir"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:background="@android:color/transparent"/>

            </LinearLayout>

        </LinearLayout>

        <!-- MINI IMAGENES -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"/>

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"/>

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"/>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- PRECIO -->
        <TextView
            android:id="@+id/txtPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$25"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="16dp"/>

        <!-- UNIDAD -->
        <TextView
            android:id="@+id/txtUnidadVenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kg"
            android:textColor="#666666"
            android:textSize="14sp"/>

        <!-- ENTREGABLE -->
        <TextView
            android:id="@+id/txtEntregable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Envío disponible"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"/>

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="18dp"/>

        <!-- BOTONES -->
        <Button
            android:id="@+id/btVerMas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver descripción completa"
            android:layout_marginTop="18dp"
            android:backgroundTint="#B7C7BA"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btDetalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver más detalles"
            android:layout_marginTop="10dp"
            android:backgroundTint="#B7C7BA"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btnAgregarCarrito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar al carrito"
            android:layout_marginTop="10dp"
            android:backgroundTint="#000000"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>