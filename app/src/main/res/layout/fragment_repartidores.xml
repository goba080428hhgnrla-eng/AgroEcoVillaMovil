<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEDED"
    android:padding="16dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/logo"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Formulario de Repartidor"
            android:textStyle="bold"
            android:textSize="23dp"
            android:textColor="@color/txt_inicio"
            android:fontFamily="serif"
            android:layout_marginBottom="40dp"/>

        <!-- Nombre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre Completo"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="serif"/>

        <EditText
            android:id="@+id/etNombre"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@color/white"
            android:layout_marginBottom="20dp"
            android:padding="10dp"
            android:textColor="@color/black"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"/>

        <!-- Correo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correo Electronico"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="serif"/>

        <EditText
            android:id="@+id/etCorreo"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@color/white"
            android:layout_marginBottom="20dp"
            android:padding="10dp"
            android:inputType="textEmailAddress"
            android:textColor="@color/black"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"/>

        <!-- Teléfono -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Numero telefono"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="serif"/>

        <EditText
            android:id="@+id/etTelefono"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@color/white"
            android:layout_marginBottom="20dp"
            android:padding="10dp"
            android:inputType="phone"
            android:textColor="@color/black"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"/>

        <!-- Automóvil -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automovil"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="serif"/>

        <EditText
            android:id="@+id/etAutomovil"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@color/white"
            android:layout_marginBottom="25dp"
            android:padding="10dp"
            android:textColor="@color/black"
            android:hint="Ingresa tu automóvil"/>

        <!-- Botón -->
        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Mandar solicitud"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:backgroundTint="@color/botones"/>

    </LinearLayout>

</ScrollView>